# ==============================================
# 屏蔽核心规则
# ==============================================
# 1. 100%完全忽略整个build目录，所有中间编译文件全屏蔽
/build/
/third_lib/
.tool/
# 2. 先屏蔽output目录下的所有内容（避免临时文件、冗余产物污染仓库）
/output/*
# ==============================================
# 放行核心规则
# ==============================================
# 3. 精准放行你需要跟踪的可执行文件（一行一个，后续新增直接加）
!/output/vision_ai_app
# 【扩展示例】后续新增要跟踪的库/产物，直接加对应行即可
# !/output/libutils.a       # 放行你编译的静态库
# !/output/libvision_ai.so  # 放行你编译的动态库

# ==============================================
# 嵌入式Linux开发通用忽略规则（必加，避免仓库污染）
# ==============================================
# 编译相关临时文件（防止子目录零散中间文件被误提交）
*.o
*.a
*.so
*.so.*
*.d
*.ko
*.mod
*.mod.c
*.symvers
*.order
*.elf
*.bin
*.hex
*.map

# 编辑器/IDE临时缓存文件
# Vim/Nano（Linux开发常用）
*.swp
*.swo
*~
.#*
# VSCode/Clion
# .vscode/
.idea/
*.code-workspace
# Windows系统缓存
.DS_Store
Thumbs.db

# 系统/WSL临时文件
*.log
*.tmp
*.temp
.cache/