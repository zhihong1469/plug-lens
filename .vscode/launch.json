{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Remote GDB (ARM)",
      "type": "cppdbg",
      "request": "launch",
      // 本地【带调试信息】的可执行文件（和目标板一致）
      "program": "${workspaceFolder}/output/vision_ai_app",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [],
      "externalConsole": false,
      "MIMode": "gdb",
      // 本地交叉 GDB 路径（关键！）
      "miDebuggerPath": "/usr/local/arm/ToolChain/arm-buildroot-linux-gnueabihf_sdk-buildroot/bin/arm-buildroot-linux-gnueabihf-gdb",
      // 目标板 IP:端口
      "miDebuggerServerAddress": "192.168.5.9:12345",
      "setupCommands": [
        {
          "description": "Enable pretty-printing",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ]
    }
  ]
}