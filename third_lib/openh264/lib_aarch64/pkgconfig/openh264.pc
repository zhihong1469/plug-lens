prefix=/home/luo/linux/6ull/project/plug-lens/.tool/openh264-2.5.1/install
libdir=/home/luo/linux/6ull/project/plug-lens/.tool/openh264-2.5.1/install/lib
includedir=${prefix}/include

Name: OpenH264
Description: OpenH264 is a codec library which supports H.264 encoding and decoding. It is suitable for use in real time applications such as WebRTC.
Version: 2.5.1
Libs: -L${libdir} -lopenh264 
Libs.private: -lstdc++ -lpthread -lm
Cflags: -I${includedir}
