# 1. 源文件（相对于 lib/ 目录）
SRC_FILES := src/log.c

# 2. 头文件路径（让编译器能找到 inc/log.h）
INC_FLAGS := -I$(SRC_DIR)/inc

# 3. 定义目标：静态库 liblog.a
TARGET_NAME := liblog.a
TARGET_TYPE := LIB

# 4. 库不需要链接选项
LDFLAGS :=